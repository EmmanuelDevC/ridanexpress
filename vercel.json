{
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "https://ridan-express-backend-wpxq.onrender.com/api/$1"
      },
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/api/(.*)",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "https://ridanexpress-client.vercel.app" },
          { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" }
        ]
      }
    ]
  }